%% Data Flow - Dashboard Widgets
sequenceDiagram
    participant User
    participant Dashboard
    participant Hook
    participant ServerAction
    participant MongoDB
    participant TradingView
    
    User->>Dashboard: Load Dashboard
    Dashboard->>Hook: useDashboardLayout(userId)
    Hook->>ServerAction: getUserDashboardLayout(userId)
    ServerAction->>MongoDB: Query UserPreferences
    MongoDB-->>ServerAction: Return Layout Data
    ServerAction-->>Hook: Return Layout
    Hook-->>Dashboard: Provide Layout State
    
    Dashboard->>TradingView: Render Widgets
    TradingView-->>Dashboard: Display Charts
    
    User->>Dashboard: Drag/Resize Widget
    Dashboard->>Hook: handleLayoutChange(newLayout)
    Hook->>ServerAction: saveUserDashboardLayout(userId, layout)
    ServerAction->>MongoDB: Update UserPreferences
    MongoDB-->>ServerAction: Confirm Update
    ServerAction-->>Hook: Success
    Hook-->>Dashboard: Update State

%% Background Jobs Flow
graph TB
    subgraph "Inngest Functions"
        UserCreated[User Created Event]
        DailyCron[Daily Cron Job]
    end
    
    subgraph "Welcome Email Flow"
        UserCreated --> GetProfile[Get User Profile]
        GetProfile --> BuildPrompt[Build AI Prompt]
        BuildPrompt --> CallAI[Call Gemini AI]
        CallAI --> GenerateIntro[Generate Personalized Intro]
        GenerateIntro --> SendWelcome[Send Welcome Email]
    end
    
    subgraph "Daily News Summary Flow"
        DailyCron --> GetUsers[Get All Users]
        GetUsers --> ForEachUser{For Each User}
        ForEachUser --> GetWatchlist[Get User Watchlist]
        GetWatchlist --> FetchNews[Fetch News from Finnhub]
        FetchNews --> CheckNews{News Found?}
        CheckNews -->|No| FetchGeneral[Fetch General News]
        CheckNews -->|Yes| SummarizeNews[Summarize with AI]
        FetchGeneral --> SummarizeNews
        SummarizeNews --> SendNewsEmail[Send News Email]
        SendNewsEmail --> ForEachUser
    end
    
    SendWelcome --> Nodemailer[Nodemailer Service]
    SendNewsEmail --> Nodemailer
    Nodemailer --> EmailProvider[Email Provider]

    style UserCreated fill:#0FEDBE,stroke:#0FEDBE,color:#141414
    style DailyCron fill:#0FEDBE,stroke:#0FEDBE,color:#141414
    style CallAI fill:#212328,stroke:#0FEDBE,color:#DBDBDB
    style SummarizeNews fill:#212328,stroke:#0FEDBE,color:#DBDBDB

