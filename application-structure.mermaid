%% User Authentication Flow
graph LR
    Start([User Visits]) --> Check{Authenticated?}
    Check -->|No| PublicDash[Public Dashboard]
    Check -->|Yes| UserDash[User Dashboard]
    
    PublicDash --> SignUp[Sign Up Page]
    PublicDash --> SignIn[Sign In Page]
    
    SignUp --> SignUpForm[Sign Up Form]
    SignUpForm --> CollectPrefs[Collect Preferences]
    CollectPrefs --> CreateUser[Create User Account]
    CreateUser --> SavePrefs[Save User Preferences]
    SavePrefs --> TriggerEvent[Trigger Inngest Event]
    TriggerEvent --> WelcomeEmail[Send Welcome Email]
    WelcomeEmail --> RedirectDash[Redirect to Dashboard]
    
    SignIn --> SignInForm[Sign In Form]
    SignInForm --> Validate[Validate Credentials]
    Validate -->|Success| Session[Create Session]
    Validate -->|Fail| Error[Show Error]
    Session --> RedirectDash
    
    RedirectDash --> LoadDash[Load User Dashboard]
    LoadDash --> LoadLayout[Load Saved Layout]
    LoadLayout --> RenderWidgets[Render TradingView Widgets]

    style Start fill:#0FEDBE,stroke:#0FEDBE,color:#141414
    style CreateUser fill:#212328,stroke:#0FEDBE,color:#DBDBDB
    style WelcomeEmail fill:#212328,stroke:#0FEDBE,color:#DBDBDB

%% Database Schema
erDiagram
    USER ||--o{ USER_PREFERENCES : has
    USER ||--o{ WATCHLIST : has
    
    USER {
        string id PK
        string email UK
        string name
        datetime createdAt
        datetime updatedAt
    }
    
    USER_PREFERENCES {
        string userId PK,FK
        string investmentGoals
        string riskTolerance
        string preferredIndustry
        string country
        json dashboardLayout
        datetime createdAt
        datetime updatedAt
    }
    
    WATCHLIST {
        string _id PK
        string userId FK
        string symbol UK
        string company
        datetime addedAt
    }

